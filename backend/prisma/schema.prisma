

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id     Int @id @default(autoincrement())
  name     String
  category     String
  price     Float
  stock     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Sale {
  id        Int      @id @default(autoincrement())
  product   String
  quantity  Int
  total     Float
  createdAt DateTime @default(now())
}