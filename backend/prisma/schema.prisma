

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id     Int @id @default(autoincrement())
  name     String
  category     String
  price     Float
  stock     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}